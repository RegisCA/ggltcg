# GGLTCG Environment Variables
# Copy this file to .env and fill in your API key
# DO NOT commit .env to git!

# ===== AI Player Configuration =====

# Optional: select AI provider.
# Supported: gemini, groq, openrouter
# Default: gemini
# AI_PROVIDER=gemini

# Optional: generic model override used by the selected provider.
# Examples:
#   gemini-3.1-flash-lite-preview
#   llama-3.3-70b-versatile
#   openai/gpt-oss-20b
# AI_MODEL=

# Optional: generic fallback model override used by the selected provider.
# AI_FALLBACK_MODEL=

# AI planner mode. NOTE: in the running app the mode is selected by AI_VERSION
# below, NOT by AI_PLANNER_MODE — get_ai_player() derives the mode from AI_VERSION
# and bypasses the function that reads AI_PLANNER_MODE. This var is currently a
# no-op (unfinished AI_VERSION -> AI_PLANNER_MODE migration). Set AI_VERSION instead.
# AI_PLANNER_MODE=single

# AI version = the real planner-mode switch.
#   4 = dual / "V4" two-request planning (sequence gen -> validator -> selection).
#       This is what production runs (on Gemini). Costs ~2 LLM calls/turn.
#   3 or unset = single one-request whole-turn planning (~1 call/turn, cheaper).
# Leave unset for single (default), or set 4 to reproduce production's V4 behavior.
# AI_VERSION=4

# Google Gemini API Key (FREE)
# Get a free key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Groq API Key (experimental OpenAI-compatible provider)
# Get a key at: https://console.groq.com/keys
# GROQ_API_KEY=your-groq-api-key-here

# OpenRouter API Key (experimental OpenAI-compatible provider)
# Get a key at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: Override default Gemini model
# Default: gemini-3.1-flash-lite-preview
# If you get 429 errors, set AI_MODEL or GEMINI_MODEL explicitly.
# GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Optional: Fallback model when primary model hits capacity (429 errors)
# Default: same as primary model
# GEMINI_FALLBACK_MODEL=gemini-3.1-flash-lite-preview

# ===== Authentication Configuration =====

# Google OAuth 2.0 Credentials
# Get these from: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID
# 2. Add authorized redirect URIs (see docs/development/GOOGLE_OAUTH_SETUP.md)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# JWT Secret Key
# Generate a secure random key with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# IMPORTANT: Use different secrets for development and production!
JWT_SECRET_KEY=your_random_secret_key_here

# CORS Configuration
# Comma-separated list of allowed frontend origins
# Add all domains where your frontend runs
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://ggltcg.vercel.app

# ===== Error Tracking =====

# Environment (development, staging, production)
ENVIRONMENT=development

# Sentry DSN for backend error tracking
# Get this from: https://sentry.io/settings/projects/<your-project>/keys/
# Leave empty for local development (errors will only log to console)
SENTRY_DSN=

# ===== Database Configuration =====

# PostgreSQL Database URL
# Format: postgresql://user:password@host:port/dbname
# For local development:
#   DATABASE_URL=postgresql://postgres:password@localhost:5432/ggltcg
# For Render (production), this is auto-configured by the service
DATABASE_URL=your_database_url_here
