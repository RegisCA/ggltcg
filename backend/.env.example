# GGLTCG Environment Variables
# Copy this file to .env and fill in your API key
# DO NOT commit .env to git!

# ===== AI Player Configuration =====
#
# The AI player has a single architecture: deterministic enum-based action
# enumeration plus one Gemini strategic-selection LLM call per turn. There is
# no provider or planner-mode switch — Gemini is the only supported provider.

# Google Gemini API Key (FREE)
# Get a free key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Optional: Override default Gemini model
# Default: gemini-flash-lite-latest
# If you get 429 errors, set GEMINI_MODEL explicitly.
# GEMINI_MODEL=gemini-flash-lite-latest

# Optional: Fallback model when primary model hits capacity (429 errors)
# Default: gemini-2.5-flash-lite
# GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

# ===== Authentication Configuration =====

# Google OAuth 2.0 Credentials
# Get these from: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID
# 2. Add authorized redirect URIs (see docs/development/GOOGLE_OAUTH_SETUP.md)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# JWT Secret Key
# Generate a secure random key with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# IMPORTANT: Use different secrets for development and production!
JWT_SECRET_KEY=your_random_secret_key_here

# CORS Configuration
# Comma-separated list of allowed frontend origins
# Add all domains where your frontend runs
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://ggltcg.vercel.app

# ===== Error Tracking =====

# Environment (development, staging, production)
ENVIRONMENT=development

# Sentry DSN for backend error tracking
# Get this from: https://sentry.io/settings/projects/<your-project>/keys/
# Leave empty for local development (errors will only log to console)
SENTRY_DSN=

# ===== Database Configuration =====

# PostgreSQL Database URL
# Format: postgresql://user:password@host:port/dbname
# For local development:
#   DATABASE_URL=postgresql://postgres:password@localhost:5432/ggltcg
# For Render (production), this is auto-configured by the service
DATABASE_URL=your_database_url_here
